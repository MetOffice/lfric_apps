    }) %}

{% elif task_ns.conf_name == "oasis_clim_gal9_C12-ral_seuk_C16_lam_4cpu" %}

    {% do task_dict.update({
        "opt_confs": [ "oasis","source-C12","destination-seuk","multi-cpu"],
