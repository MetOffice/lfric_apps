module compute_geopotential_kernel_mod_test

  use constants_mod, only : i_def, r_def, l_def
  use funit

  implicit none

  private
  public :: compute_geopotential_kernel_test_type, test_all

  @TestCase
  type, extends(TestCase) :: compute_geopotential_kernel_test_type
    private
    integer(i_def), allocatable :: map(:)
    real(r_def),    allocatable :: z(:), phi(:)
  contains
    procedure setUp
    procedure tearDown
    procedure test_all
  end type compute_geopotential_kernel_test_type

  integer(i_def), parameter :: nlayers = 1, &
                               ndf     = 1, &
                               undf    = 1

  real(r_def), parameter :: gravity  = 10.0_r_def
  real(r_def), parameter :: radius   = 6000000.0_r_def

contains

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  subroutine setUp( this )

    implicit none

    class(compute_geopotential_kernel_test_type), intent(inout) :: this

    allocate( this%map(ndf), &
              this%z(undf),  &
              this%phi(undf) )

  end subroutine setUp

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  subroutine tearDown( this )

    implicit none

    class(compute_geopotential_kernel_test_type), intent(inout) :: this

    deallocate( this%map, this%z, this%phi )

  end subroutine tearDown

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_all( this )

    use compute_geopotential_kernel_mod, only: compute_geopotential_code

    implicit none

    class(compute_geopotential_kernel_test_type), intent(inout) :: this

    real(r_def), parameter :: tol = 1.0e-8_r_def
    logical(l_def) :: shallow

    real(r_def) :: answer

    this%map(1) = 1
    this%z(1)   = 10000.0_r_def


    ! Test shallow geometry
    shallow = .true.
    call compute_geopotential_code( nlayers,                          &
                                    this%phi, this%z,                 &
                                    gravity, radius, shallow,         &
                                    ndf, undf, this%map )

    ! answer = gravity * (z - radius)
    answer = gravity * 10000.0_r_def
    @assertEqual( answer, this%phi(1), tol )

    ! Test deep geometry
    shallow = .false.
    call compute_geopotential_code( nlayers,                          &
                                    this%phi, this%z,                 &
                                    gravity, radius, shallow,         &
                                    ndf, undf, this%map )

    ! answer = radius * gravity * (1 - (radius/(radius + height))
    answer = 60000000.0_r_def * ( 1.0_r_def - 6000000.0_r_def/6010000.0_r_def)
    @assertEqual( answer, this%phi(1), tol )

  end subroutine test_all

end module compute_geopotential_kernel_mod_test
