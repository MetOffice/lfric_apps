!> Test the kernel for diffusion flux calculation of momentum.
!>
module diffusion_momentum_flux_kernel_mod_test

  use constants_mod,                       only : i_def, r_def, l_def
  use get_unit_test_m3x3_q3x3x3_sizes_mod, only : get_w3_m3x3_q3x3x3_size,  &
                                                  get_w1_m3x3_q3x3x3_size,  &
                                                  get_w2h_m3x3_q3x3x3_size, &
                                                  get_w2_m3x3_q3x3x3_size
  use get_unit_test_m3x3_dofmap_mod,       only : get_w3_m3x3_dofmap,       &
                                                  get_w1_m3x3_dofmap,       &
                                                  get_w2h_m3x3_dofmap,      &
                                                  get_w2_m3x3_dofmap,       &
                                                  get_m3x3_stencil_dofmap_cross
  use funit

  implicit none

  private
  public :: test_all

  @TestCase
  type, extends(TestCase), public :: diffusion_momentum_flux_kernel_test_type
    private

  contains
    procedure test_all
  end type diffusion_momentum_flux_kernel_test_type

contains

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_all( this )

    use feign_config_mod,                   only : feign_mixing_config
    use mixing_config_mod,                  only : method_3d_smag, &
                                                   smag_l_calc_UseDx
    use diffusion_momentum_flux_kernel_mod, only : diffusion_momentum_flux_code

    implicit none

    class(diffusion_momentum_flux_kernel_test_type), intent(inout) :: this

    integer(kind=i_def), parameter :: nlayers = 3
    integer(kind=i_def), parameter :: stemcil_map_size = 5
    integer(kind=i_def) :: ncells
    integer(kind=i_def) :: ndf_w3
    integer(kind=i_def) :: ndf_w1
    integer(kind=i_def) :: ndf_sh_w2h
    integer(kind=i_def) :: ndf_w2
    integer(kind=i_def) :: ndf_sh_w2
    integer(kind=i_def) :: ndf_w2h
    integer(kind=i_def) :: ndf_pid
    integer(kind=i_def) :: ndf_w3_2d
    integer(kind=i_def) :: undf_w3
    integer(kind=i_def) :: undf_w1
    integer(kind=i_def) :: undf_sh_w2h
    integer(kind=i_def) :: undf_w2
    integer(kind=i_def) :: undf_sh_w2
    integer(kind=i_def) :: undf_w2h
    integer(kind=i_def) :: undf_pid
    integer(kind=i_def) :: undf_w3_2d
    integer(kind=i_def) :: dim_space, dim_space_diff
    integer(kind=i_def) :: nqp_h, nqp_v
    integer(kind=i_def), allocatable :: map_w3(:,:)
    integer(kind=i_def), allocatable :: map_w1(:,:)
    integer(kind=i_def), allocatable :: map_sh_w2h(:,:)
    integer(kind=i_def), allocatable :: map_w2(:,:)
    integer(kind=i_def), allocatable :: map_sh_w2(:,:)
    integer(kind=i_def), allocatable :: map_w2h(:,:)
    integer(kind=i_def), allocatable :: map_pid(:,:)
    integer(kind=i_def), allocatable :: map_w3_2d(:,:)
    integer(kind=i_def), allocatable :: smap_w2(:,:,:)
    integer(kind=i_def), allocatable :: smap_w2h(:,:,:)
    integer(kind=i_def), allocatable :: smap_pid(:,:,:)
    real(kind=r_def), allocatable :: uflux_w3(:)
    real(kind=r_def), allocatable :: vflux_w3(:)
    real(kind=r_def), allocatable :: uflux_w1(:)
    real(kind=r_def), allocatable :: vflux_w1(:)
    real(kind=r_def), allocatable :: wflux_sh_w2h(:)
    real(kind=r_def), allocatable :: u_physics(:)
    real(kind=r_def), allocatable :: dx_at_w2(:)
    real(kind=r_def), allocatable :: dA_at_w2(:)
    real(kind=r_def), allocatable :: dx_at_sh_w2(:)
    real(kind=r_def), allocatable :: dA_at_sh_w2(:)
    real(kind=r_def), allocatable :: visc_m_w2h(:)
    real(kind=r_def), allocatable :: visc_m_sh_w2h(:)
    real(kind=r_def), allocatable :: visc_m_w3(:)
    real(kind=r_def), allocatable :: rho_in_w3(:)
    real(kind=r_def), allocatable :: rho_in_sh_w2h(:)
    real(kind=r_def), allocatable :: rho_in_w2h(:)
    real(kind=r_def), allocatable :: panel_id(:)
    integer(i_def), allocatable :: face_selector_ew(:)
    integer(i_def), allocatable :: face_selector_ns(:)
    real(kind=r_def), parameter :: tol = 1.0e-6_r_def
    real(kind=r_def), parameter :: dh = 1000.0_r_def, &
                                   dz = 200.0_r_def,  &
                                   dAh = dh*dz,       &
                                   dAv = dh**2,       &
                                   du = 1.0_r_def,    &
                                   dv = 2.0_r_def,    &
                                   visc = 1.0_r_def,  &
                                   rho = 1.0_r_def
    real(r_def) :: answer

    integer(kind=i_def) :: icell, i, j, k, df
    integer(kind=i_def) :: cell
    logical(kind=l_def), parameter :: fullstress = .true.

    cell = 5

    call feign_mixing_config( viscosity     = .false.,           &
                              viscosity_mu  = 0.0_r_def,         &
                              smagorinsky   = .true.,            &
                              fullstress    = fullstress,        &
                              mix_factor    = 0.2_r_def,         &
                              method        = method_3d_smag,    &
                              smag_l_calc   = smag_l_calc_UseDx, &
                              leonard_term  = .false.,           &
                              leonard_kl    = 4.0_r_def,         &
                              conservative_diffusion = .true.,   &
                              density_weighted = .true.,         &
                              max_diff_factor=1.0_r_def )

    ! Variables for testing momentum_smagorinsky
    ! Get sizes of everything
    call get_w3_m3x3_q3x3x3_size( ndf_w3, undf_w3, ncells,          &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers )

    call get_w1_m3x3_q3x3x3_size( ndf_w1, undf_w1, ncells,          &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers )

    call get_w2h_m3x3_q3x3x3_size( ndf_sh_w2h, undf_sh_w2h, ncells, &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers+1 )

    call get_w2_m3x3_q3x3x3_size( ndf_w2, undf_w2, ncells,          &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers )

    call get_w2_m3x3_q3x3x3_size( ndf_sh_w2, undf_sh_w2, ncells,    &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers+1 )

    call get_w2h_m3x3_q3x3x3_size( ndf_w2h, undf_w2h, ncells, &
                                  dim_space, dim_space_diff,        &
                                  nqp_h, nqp_v,                     &
                                  nlayers )

    call get_w3_m3x3_q3x3x3_size( ndf_pid, undf_pid, ncells, &
                                  dim_space, dim_space_diff, &
                                  nqp_h, nqp_v,              &
                                  1 )

    call get_w3_m3x3_q3x3x3_size( ndf_w3_2d, undf_w3_2d, ncells, &
                                  dim_space, dim_space_diff,     &
                                  nqp_h, nqp_v,                  &
                                  1 )

    ! Setup maps
    call get_w3_m3x3_dofmap(map_w3, nlayers)
    call get_w1_m3x3_dofmap(map_w1, nlayers)
    call get_w2h_m3x3_dofmap(map_sh_w2h, nlayers+1)
    call get_w2_m3x3_dofmap(map_w2, nlayers)
    call get_w2_m3x3_dofmap(map_sh_w2, nlayers+1)
    call get_w2h_m3x3_dofmap(map_w2h, nlayers)
    call get_w3_m3x3_dofmap(map_pid, 1)
    call get_w3_m3x3_dofmap(map_w3_2d, 1)

    call get_m3x3_stencil_dofmap_cross(smap_w2, map_w2)
    call get_m3x3_stencil_dofmap_cross(smap_w2h, map_w2h)
    call get_m3x3_stencil_dofmap_cross(smap_pid, map_pid)

    ! Create the data
    allocate(uflux_w3(undf_w3))
    allocate(vflux_w3(undf_w3))
    allocate(uflux_w1(undf_w1))
    allocate(vflux_w1(undf_w1))
    allocate(wflux_sh_w2h(undf_sh_w2h))
    allocate(u_physics(undf_w2))
    allocate(dx_at_w2(undf_w2))
    allocate(dA_at_w2(undf_w2))
    allocate(dx_at_sh_w2(undf_sh_w2))
    allocate(dA_at_sh_w2(undf_sh_w2))
    allocate(visc_m_w2h(undf_w2h))
    allocate(visc_m_sh_w2h(undf_sh_w2h))
    allocate(visc_m_w3(undf_w3))
    allocate(rho_in_w3(undf_w3))
    allocate(rho_in_sh_w2h(undf_sh_w2h))
    allocate(rho_in_w2h(undf_w2h))
    allocate(panel_id(undf_pid))
    allocate(face_selector_ew(undf_w3_2d))
    allocate(face_selector_ns(undf_w3_2d))

    u_physics(:) = 1.0_r_def
    ! Create non-uniform wind to generate some diffusion
    u_physics(map_w2(3,cell)) = u_physics(map_w2(3,cell)) + du
    u_physics(map_w2(4,cell)) = u_physics(map_w2(4,cell)) - dv

    icell = 1
    do j = 1,3
      do i = 1,3
        do df=1,4
          do k = 0,nlayers-1
            dx_at_w2(map_w2(df,icell)+k) = dh
            dA_at_w2(map_w2(df,icell)+k) = dAh
          end do
          do k = 0,nlayers
            dx_at_sh_w2(map_sh_w2(df,icell)+k) = dh
            dA_at_sh_w2(map_w2(df,icell)+k) = dAh
          end do
        end do
        do k = 0,nlayers
          dx_at_w2(map_w2(5,icell)+k) = dz
          dA_at_w2(map_w2(5,icell)+k) = dAv
        end do
        do k = 0,nlayers
          dx_at_sh_w2(map_sh_w2(5,icell)+k) = dz
          dA_at_sh_w2(map_sh_w2(5,icell)+k) = dAv
        end do
        icell = icell + 1
      end do
    end do

    visc_m_w2h(:) = visc
    visc_m_sh_w2h(:) = visc
    visc_m_w3(:) = visc
    rho_in_w3(:) = rho
    rho_in_sh_w2h(:) = rho
    rho_in_w2h(:) = rho
    panel_id(:) = 1.0_r_def
    face_selector_ew(:) = 2
    face_selector_ns(:) = 2

    ! Flux needs to be zeroed out before the kernel is called.
    uflux_w3(:) = 0.0_r_def
    vflux_w3(:) = 0.0_r_def
    uflux_w1(:) = 0.0_r_def
    vflux_w1(:) = 0.0_r_def
    wflux_sh_w2h(:) = 0.0_r_def

    call diffusion_momentum_flux_code(                                         &
           nlayers,                                                            &
           uflux_w3, vflux_w3, uflux_w1, vflux_w1, wflux_sh_w2h,               &
           u_physics, stemcil_map_size, smap_w2(:,:,cell),                     &
           dx_at_w2, stemcil_map_size, smap_w2(:,:,cell),                      &
           dA_at_w2, stemcil_map_size, smap_w2(:,:,cell),                      &
           dx_at_sh_w2, dA_at_sh_w2,                                           &
           visc_m_w2h, stemcil_map_size, smap_w2h(:,:,cell),                   &
           visc_m_sh_w2h, visc_m_w3,                                           &
           rho_in_w3, rho_in_sh_w2h,                                           &
           rho_in_w2h, stemcil_map_size, smap_w2h(:,:,cell),                   &
           panel_id, stemcil_map_size, smap_pid(:,:,cell),                     &
           face_selector_ew, face_selector_ns,                                 &
           ndf_w3, undf_w3, map_w3(:,cell),                                    &
           ndf_w1, undf_w1, map_w1(:,cell),                                    &
           ndf_sh_w2h, undf_sh_w2h, map_sh_w2h(:,cell),                        &
           ndf_w2, undf_w2, map_w2(:,cell),                                    &
           ndf_sh_w2, undf_sh_w2, map_sh_w2(:,cell),                           &
           ndf_w2h, undf_w2h, map_w2h(:,cell),                                 &
           ndf_pid, undf_pid, map_pid(:,cell),                                 &
           ndf_w3_2d, undf_w3_2d, map_w3_2d(:,cell)                            &
         )

    if (fullstress) then
      answer = -2*rho*visc*du/dh * dAh
    else
      answer = -rho*visc*du/dh * dAh
    end if
    @assertEqual(answer, uflux_w3(map_w3(1,cell)), tol)

    if (fullstress) then
      answer = -rho*visc*(-du/dh - dv/dh) * dAh
    else
      answer = -rho*visc*(-du)/dh * dAh
    end if
    @assertEqual(answer, uflux_w1(map_w1(7,cell)), tol)

    if (fullstress) then
      answer = -rho*visc*(-du)/dz * dAh
    else
      answer = 0.0_r_def
    end if
    @assertEqual(answer, wflux_sh_w2h(map_sh_w2h(3,cell)+1), tol)

  end subroutine test_all

end module diffusion_momentum_flux_kernel_mod_test
